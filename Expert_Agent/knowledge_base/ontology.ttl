    ex:derivedFrom """
A unique UUID (`/data/instance_id`) is generated on first boot and persisted to the `instance_data` Docker volume.""" ;
    ex:generate ex:first_boot .

ex:user rdfs:label "user" ;
    ex:derivedFrom """AI verifies that for the intent `ContractAnalysis`, the user (Guest) has permission.
    -""" ;
    ex:verify ex:intent .

ex:values rdfs:label "values" ;
    ex:derive ex:formalized_evaluation_suite ;
    ex:derivedFrom "These values are derived from the project's formalized evaluation suite." .

ex:vendor_db_Configure_rate rdfs:label "vendor_db Configure rate" ;
    ex:Set ex:random_value ;
    ex:derivedFrom """
- [ ] Set `VENDOR_HMAC_SECRET` to a cryptographically random value (≥ 32 bytes)
- [ ] Set `VENDOR_JWT_SECRET` to a cryptographically random value
- [ ] Put `vendor_api` behind HTTPS (nginx + certbot or Cloudflare)
- [ ] Restrict `vendor_db` port 5435 to internal traffic only
- [ ] Set up PostgreSQL backups for `vendor_db`
- [ ] Configure rate limiting on `/api/license/check` and `/api/heartbeat` endpoints
""" .

ex:vendor_platform rdfs:label "vendor platform" ;
    ex:be ex:enterprise_deployments ;
    ex:derivedFrom """
The vendor platform is completely separate from enterprise deployments.""" .

ex:vendor_vendor_API_API_database rdfs:label "vendor vendor API API database" ;
    ex:derivedFrom """**
- The vendor database (`vendor_db`) runs on port 5435 and should be firewall-restricted to the vendor API container only.
- All API endpoints under `/admin/*` require a valid JWT token.
""" ;
    ex:require ex:port .

