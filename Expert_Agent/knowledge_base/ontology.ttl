ex: rdfs:label "*",
        "=" ;
    ex:be ex:Hybrid_Neuro_Symbolic_Conversational_enterprise_knowledge_regulated_Architecture ;
    ex:derivedFrom """*   **Integration**: Primarily triggered in "External" mode or as a secondary fallback during reasoning.

""",
        """**Auditing**: The final trace is saved to JSONL and the transaction DB.

""",
        "The **Expert Agent** is a Hybrid Neuro-Symbolic Conversational Architecture designed for enterprise knowledge retrieval in regulated environments." ;
    ex:save ex:transaction_JSONL ;
    ex:trigger ex:External_mode .

