@prefix ex: <http://expert-agent.ai/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

ex:Admin a owl:Class ;
    rdfs:label "Admin" ;
    ex:click ex: ;
    ex:derivedFrom """*   **Reindexing**: Admin can force a full reindex to refresh embeddings if the model or chunking strategy changes.

""",
        """Admin can set risk levels and confidence thresholds.
""",
        """Admin clicks **Approve** (adds to formal KG) or **Reject** (prunes from queue).
    """ ;
    ex:force ex: ;
    ex:set ex:risk_confidence_levels .

ex:Admin_Dashboard a owl:Class ;
    rdfs:label "Admin Dashboard" ;
    ex:derivedFrom """
The Admin Dashboard provides the "Symbolic Control Surface" for the system.

""" ;
    ex:provide ex:Symbolic_Control_Surface .

ex:Answer_Planning_Layer rdfs:label "* Answer Planning Layer" ;
    ex:create ex:structured_blueprint ;
    ex:derivedFrom """**Answer Planning Layer**: Creates a structured "blueprint" for the LLM to follow.
""" .

ex:Automatic_Subject_Verb_extraction a owl:Class ;
    rdfs:label "Automatic Subject Verb extraction" ;
    ex:be ex:Triples ;
    ex:derivedFrom """KG - verified=True]
    Admin -- Reject --> Trash[Discarded Triples]
    KG --> Persistence[kb.ttl Filesystem]
```

*   **The Problem**: Automatic SVO (Subject-Verb-Object) extraction from documents can be noisy.
""" .

ex:Branch_Review_Compliance_Review_Level a owl:Class ;
    rdfs:label "Branch Review Compliance Review Level" ;
    ex:require ex:An_escalation_level_for_compliance_review_based_on_branch_activity .

ex:Chunks a owl:Class ;
    rdfs:label "Chunks" ;
    ex:derivedFrom """**Tier 3**: Chunks are scored for relevance, compatibility, and recency.
    """ ;
    ex:score ex:relevance .

ex:Collateral_Requirements a owl:Class ;
    rdfs:label "Collateral Requirements" ;
    ex:requires ex:Specific_collateral_requirements_for_each_loan_category .

ex:Corporate_Risk_Assessment a owl:Class ;
    rdfs:label "Corporate Risk Assessment" ;
    rdfs:subClassOf ex:The_document_covers_the_following_aspects_of_corporate_risk_assessment .

ex:Credit_Scoring_Model_Retail a owl:Class ;
    rdfs:label "Credit Scoring Model (Retail)" ;
    rdfs:subClassOf ex:Score_components_and_minimum_approval_score .

ex:Customer a owl:Class ;
    rdfs:label "Customer" ;
    ex:avoid ex:An_indicator_of_suspicious_activity_related_to_customer_behavior .

ex:Daily a owl:Class ;
    rdfs:label "Daily" ;
    ex:derivedFrom """**JSONL (Cold Storage)**:
    - `audit_db/`: Daily logs for high-throughput forensic analysis.

""" ;
    ex:log ex:high_forensic_analysis .

ex:Docker a owl:Class ;
    rdfs:label "Docker" ;
    ex:install ex:license_key .

ex:Dynamic_Loading a owl:Class ;
    rdfs:label "Dynamic Loading" ;
    ex:derivedFrom """*   **Dynamic Loading**: Rules are stored in PostgreSQL and reloaded into the `ExpertAgent` at runtime via `RuleLoader`.

""" ;
    ex:store ex:PostgreSQL .

ex:Enterprise a owl:Class ;
    rdfs:label "Enterprise" ;
    ex:contact ex:server .

ex:ExpertAgent_manage_triple a owl:Class ;
    rdfs:label "ExpertAgent.manage_triple" ;
    ex:derivedFrom """5.  `ExpertAgent.manage_triple` executes the final update to `kb.ttl`.

""" ;
    ex:execute ex:final_update .

ex:Expert_Agent a owl:Class ;
    rdfs:label "Expert Agent" ;
    ex:act ex: ;
    ex:derivedFrom """**Control**: The Expert Agent (Symbolic) acts as a supervisor, pruning LLM outputs and enforcing rigid constraints.
""",
        """**Expert Check**:
    - Expert Agent verifies that for the intent `ContractAnalysis`, the user (Guest) has permission.
    -""" ;
    ex:verify ex:intent .

ex:Expert_Agent_env a owl:Class ;
    rdfs:label "Expert_Agent/.env" ;
    ex:set ex:variables .

ex:Expert_Arbitration a owl:Class ;
    rdfs:label "Expert Arbitration" ;
    ex:derivedFrom """**Arbitration**: Expert rules validate intents; conflicts are resolved via ontology priority.
""" ;
    ex:resolve ex:intents .

ex:ExplanationGenerator a owl:Class ;
    rdfs:label "ExplanationGenerator" ;
    ex:derivedFrom """**Ollama Connection**: The `ExplanationGenerator` tests connectivity to the local LLM.

""" ;
    ex:test ex:connectivity .

ex:Fraud_detection_Money_laundering_prevention_Suspicious_transaction a owl:Class ;
    rdfs:label "Fraud detection Money laundering prevention Suspicious transaction" ;
    ex:define ex:An_automated_rule_triggered_by_suspicious_transaction_detection .

ex:General_local_questions a owl:Class ;
    rdfs:label "General local questions" ;
    ex:derivedFrom """General questions, greeting, or tasks outside the local domain (e.g., "Write a poem").

""" ;
    ex:write ex:local_domain .

ex:ID a owl:Class ;
    rdfs:label "ID" ;
    ex:send ex:license_check .

ex:Induced_triples a owl:Class ;
    rdfs:label "Induced triples" ;
    ex:derivedFrom """*   **The Solution**: Induced triples are placed in a **Validation Queue**.
""" ;
    ex:place ex:Validation_Queue .

ex:Interpretation a owl:Class ;
    rdfs:label "Interpretation" ;
    ex:derivedFrom """**Interpretation**:
    - NLP Core identifies `convention` and `stage` as French technical terms.
    - Intent Hypotheses: `ContractAnalysis (0.8)`, `General (0.4)`.
""" ;
    ex:identify ex:convention .

ex:It a owl:Class ;
    rdfs:label "It" ;
    ex:combine ex:Large_Language_deterministic_Symbolic_Expert_Formal_flexibility ;
    ex:derivedFrom "It combines the flexibility of Large Language Models (LLMs) with the deterministic control of Symbolic Reasoning (Expert Systems) and Formal Ontologies.",
        """It identifies that "Sanofi-specific" documents are required for this topic.
""" ;
    ex:identify ex:topic .

ex:KG a owl:Class ;
    rdfs:label "KG" ;
    ex:derivedFrom """- **Tier 4**: KG is searched for keywords to find formal triples.
""" ;
    ex:search ex:keywords .

ex:LICENSE_KEY a owl:Class ;
    rdfs:label "LICENSE_KEY" ;
    ex:bypass ex:skip_validation .

ex:LLM a owl:Class ;
    rdfs:label "LLM" ;
    ex:call ex:Constrained_Template ;
    ex:derivedFrom """**Generation**: The LLM is called with a **Constrained Prompt** (Template + Plan + Evidence).
""",
        """**Production**: LLM generates a cited response using only the PDF and KG facts.
""" ;
    ex:generate ex:cited_response .

ex:LOD a owl:Class ;
    rdfs:label "LOD" ;
    ex:trigger ex:Streaming_Chat_API .

ex:List a owl:Class ;
    rdfs:label "List" ;
    ex:derivedFrom """Step 2: List required signatures."
""" ;
    ex:require ex:signatures .

ex:Loan_Categories a owl:Class ;
    rdfs:label "Loan Categories" ;
    ex:isPartOf ex:The_document_covers_the_following_loan_categories .

ex:Manages_concepts a owl:Class ;
    rdfs:label "Manages concepts" ;
    ex:derivedFrom """Manages concepts, rules, and intent validation.
- `hybrid_agent.py`: A lightweight orchestrator used for LOD (Linked Open Data) fallback.
- `validation_agent.py`: Layer 7 validator that scores answers for fidelity and grounding.

""" ;
    ex:intent ex:validation .

ex:New_files a owl:Class ;
    rdfs:label "New files" ;
    ex:chunk ex:pgvector ;
    ex:derivedFrom """New files are automatically chunked and embedded into pgvector.
""" .

ex:OntologyInductionEngine a owl:Class ;
    rdfs:label "OntologyInductionEngine" ;
    ex:derivedFrom """`OntologyInductionEngine` extracts triples.
    """ ;
    ex:extract ex:triples .

ex:Planner a owl:Class ;
    rdfs:label "Planner" ;
    ex:derivedFrom "**Planning**: Planner dictates: \"Step 1: Define Convention." ;
    ex:dictate ex: .

ex:Purpose a owl:Class ;
    rdfs:label "Purpose" ;
    rdfs:subClassOf ex:To_define_standardized_procedures_for .

ex:Python a owl:Class ;
    rdfs:label "Python" ;
    ex:dependencie ex:FastAPI_application ;
    ex:derivedFrom """- `main.py`: Entry point for the FastAPI application (legacy/lite redirect).
- `Dockerfile`: Container configuration for production deployment.
- `requirements.txt`: Python dependencies (Core: FastAPI, spaCy, rdflib, pgvector).
- `RESEACH_ARCHITECTURE.md`: Conceptual background of the project.

""" .

ex:Real_operational_metrics a owl:Class ;
    rdfs:label "Real operational metrics" ;
    ex:derivedFrom """Real-time operational metrics (latency/throughput) can be monitored via the `/admin/stats` and `/admin/metrics` endpoints.

""" ;
    ex:monitor ex:endpoints .

ex:Reception a owl:Class ;
    rdfs:label "Reception" ;
    ex:derivedFrom """**Reception**: FastAPI receives JSON: `{"question": "...", "mode": "hybrid"}`.
""" ;
    ex:receive ex:JSON .

ex:Suspicious_transaction a owl:Class ;
    rdfs:label "Suspicious transaction" ;
    ex:require ex:An_automated_rule_triggered_by_specific_transaction_characteristics .

ex:Symbolic_rules a owl:Class ;
    rdfs:label "Symbolic rules" ;
    ex:derivedFrom """Symbolic rules map intents to RBAC roles and specific actions (Allow/Deny/Audit).
""" ;
    ex:map ex:intents .

ex:System a owl:Class ;
    rdfs:label "System" ;
    ex:derivedFrom """**Retrieval**:
    - Tier 1: System selects documents tagged with "HR" and "Stage".
    - Tier 2: Vectors of "convention.pdf" chunks are queried.
    - Tier 4: KG returns `(Convention, subClassOf, AdministrativeDocument)`.
""" ;
    ex:select ex:documents .

ex:Tier a owl:Class ;
    rdfs:label "Tier" ;
    ex:derivedFrom """**Tier 1**: Expert Agent filters documents by eligibility rules.
    """ ;
    ex:filter ex:documents .

ex:Top_documents a owl:Class ;
    rdfs:label "Top documents" ;
    ex:derivedFrom """- **Tier 2**: Top documents are ranked by vector similarity (pgvector).
    -""" ;
    ex:rank ex:vector_similarity .

ex:Validation a owl:Class ;
    rdfs:label "Validation" ;
    ex:derivedFrom """**Validation**: The answer is checked against the plan; if it fails (hallucinations/forbidden topics), it can be flagged or rejected.
""" ;
    ex:flag ex:plan .

ex:answer rdfs:label "answer" ;
    ex:derivedFrom """*   **Explainability**: Every answer includes a "Reasoning Trace" (retrieved docs, activated rules, intent confidence).

""" ;
    ex:retrieve ex:Reasoning_Trace .

ex:api_hybrid_py rdfs:label "api_hybrid.py" ;
    ex:derivedFrom """1.  **FastAPI Startup**: `api/api_hybrid.py` triggers the `startup_event`.
""" ;
    ex:trigger ex:startup_event .

ex:backend rdfs:label "backend" ;
    ex:logs ex:running_state .

ex:background_service rdfs:label "background service" ;
    ex:derivedFrom "*   **Knowledge Sync**: A background service (`services/knowledge_sync.py`) watches the `docs/` folder." ;
    ex:watch ex: .

ex:core_SPARQL_raw_SPARQL_specialized_entity_Handles_URI_React_interface rdfs:label "core SPARQL raw SPARQL specialized entity Handles URI React interface" ;
    ex:include ex:SPARQL_federation .

ex:create rdfs:label "create" ;
    ex:create ex:Admin_user_registration .

ex:disable rdfs:label "disable" ;
    ex:remotely ex:Disable_license_for_customer ;
    ex:specific ex:Disable_license_for_specific_instance .

ex:docker rdfs:label "docker" ;
    ex:compose ex:immediate_license_verification .

ex:document rdfs:label "document" ;
    ex:describe ex:Linked_Open_Hybrid_NLP_Expert_Agent_implementation .

ex:embedding_column rdfs:label "embedding column" ;
    ex:derivedFrom """**PGVector (Semantic)**:
    - The `embedding` column (384-dims) in `document_chunks` enables similarity search.
""" ;
    ex:enable ex:document_chunks .

ex:following_metrics rdfs:label "following metrics" ;
    ex:derivedFrom """
The following metrics represent the verified performance of the Hybrid NLP-Expert Agent based on the standardized **Research Baseline Evaluation** (5,000-query corpus). 

""" ;
    ex:represent ex:verified_Hybrid_NLP_Expert_performance .

ex:guide rdfs:label "guide" ;
    ex:cover ex:AI_Expert_Agent_platform ;
    ex:explain ex:Vendor_Platform_Guide .

ex:hybrid_approach rdfs:label "hybrid approach" ;
    ex:derivedFrom """This hybrid approach ensures that answers are grounded in verified facts, compliant with enterprise rules, and resistant to hallucinations.

""" ;
    ex:ensure ex:verified_facts .

ex:participant_D rdfs:label "participant D" ;
    ex:derivedFrom """
```mermaid
sequenceDiagram
    participant U as User
    participant S as Security Layer
    participant N as NLP Core (L1)
    participant E as Expert Agent (L2)
    participant A as Arbitrator (L3)
    participant R as Retrieval (L4)
    participant P as Planner (L5)
    participant G as Generator (L6)
    participant V as Validator (L7)
    participant D as Audit (L8)

    U->>S: Query Processing
    S->>S: PII/Injection Scan
    S->>N: Clean Query
    N->>N: Intent Hypotheses
    N->>E: Hypotheses
    E->>E: Symbolic Validation
    E->>A: Valid Intents
    A->>A: Conflict Resolution
    A->>R: Final Intent
    R->>R: Symbolic/Semantic Search
    R->>P: Context Chunks
    P->>P: Creation Answer Plan
    P->>G: Plan + Context
    G->>G: LLM Synthesis
    G->>V: Raw Answer
    V->>V: Hallucination Check
    V->>D: Final Answer
    D->>D: Logs Reasoning Trace
    D->>U:""" ;
    ex:u_s ex:sequenceDiagram_participant_User_participant_Security_Layer_U .

ex:pipeline_manager rdfs:label "pipeline_manager" ;
    ex:derivedFrom """**Pipeline Manager**: The `pipeline_manager` initializes a default `HybridPipeline` for the root domain.
""" ;
    ex:initialize ex:root_default .

ex:policy_research_filtering rdfs:label "policy research filtering" ;
    ex:decouple ex:research_paper .

ex:production_Admin rdfs:label "production Admin" ;
    ex:derivedFrom """- Uses **IF-THEN production rules**.
- Example: `IF intent = "Deployment" AND user_role != "Admin" THEN rejected = True`.

---

---

""" ;
    ex:reject ex:Example .

ex:rate rdfs:label "rate" ;
    ex:set ex:Configure_license_server_rate_limit .

ex:request rdfs:label "request" ;
    ex:derivedFrom """*   **Trace ID**: Every request gets a UUID shared across all 8 layers.
""",
        """**Audit**: The request is logged as `CHAT_QUERY` with a full trace ID.

""" ;
    ex:get ex:UUID ;
    ex:log ex:CHAT_QUERY .

ex:sign rdfs:label "sign" ;
    ex:in ex:Admin_user_login .

ex:system rdfs:label "system" ;
    ex:avoid ex:raw_SPARQL_injection ;
    ex:derivedFrom """
The system operates in three distinct reasoning modes, selectable via the `mode` parameter in the Chat API.

""",
        """*   **Filtering**: The system avoids raw SPARQL injection by using template-parameterized queries.
""",
        """The system is structured into **8 distinct layers**, following a "Neuro-Symbolic" orchestration pattern:

1.  """ ;
    ex:operate ex:distinct_reasoning_selectable_Chat_modes ;
    ex:structure ex: ;
    ex:utilize ex:external_knowledge .

ex:values rdfs:label "values" ;
    ex:derive ex:formalized_evaluation_suite ;
    ex:derivedFrom "These values are derived from the project's formalized evaluation suite." .

ex:vendor rdfs:label "vendor" ;
    ex:disable ex:license .

ex:vendor_platform rdfs:label "vendor platform" ;
    ex:be ex:Separate_from_enterprise_deployments .

